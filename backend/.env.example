# MonMan backend — copy to `.env` and load into your shell (Go does not read this file automatically).
#
# Typical usage:
#   cp .env.example .env
#   set -a && source .env && set +a    # bash/zsh — exports variables for `go run`
# Or set variables in your IDE / terminal manually.

# SQLite database file (created on first migrate / first connect)
SQLITE_PATH=./data/monman.db

# API listen port (used by cmd/server)
API_PORT=8080

APP_ENV=development

# JWT — set a strong random value for anything beyond local dev
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_TTL_HOURS=24
